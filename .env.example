VITE_AIRTABLE_API_KEY=patXXXXXXXXXXXX.sample_airtable_token
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
VITE_AIRTABLE_TABLE_NAME=tblXXXXXXXXXXXXXX
VITE_AIRTABLE_VIEW_ID=viwXXXXXXXXXXXXXX
VITE_USE_LAMBDA_AIRTABLE=false
VITE_USE_LAMBDA_JOTFORM=false
VITE_USE_LAMBDA_AI=false
VITE_USE_LAMBDA_GMAIL=false
VITE_USE_LAMBDA_SHOPIFY=false
VITE_AI_PROVIDER=github
VITE_APP_API_BASE_URL=
VITE_APP_API_PROXY_TARGET=http://127.0.0.1:3001
VITE_AIRTABLE_APPROVAL_TABLE_REF=appXXXXXXXXXXXXXX/viwXXXXXXXXXXXXXX
VITE_AIRTABLE_APPROVAL_TABLE_NAME=tblXXXXXXXXXXXXXX
VITE_AIRTABLE_SHOPIFY_APPROVAL_TABLE_REF=appYYYYYYYYYYYYYY/viwYYYYYYYYYYYYYY
VITE_AIRTABLE_SHOPIFY_APPROVAL_TABLE_NAME=tblYYYYYYYYYYYYYY
VITE_AIRTABLE_COMBINED_LISTINGS_TABLE_REF=appZZZZZZZZZZZZZZ/viwZZZZZZZZZZZZZZ
VITE_AIRTABLE_COMBINED_LISTINGS_TABLE_NAME=tblZZZZZZZZZZZZZZ

# Shopify OAuth 2.0
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SHOPIFY_OAUTH_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JotForm
VITE_JOTFORM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_JOTFORM_FORM_ID=123456789012345

# OpenAI (for Image Lab equipment identification)
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gmail API (for automatic user welcome email sending)
VITE_GOOGLE_GMAIL_ACCESS_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_GMAIL_FROM_EMAIL=noreply@yourdomain.com

# GitHub Models (alternative to OpenAI — uses Copilot subscription).
# Create a PAT at https://github.com/settings/tokens with no special scopes needed.
# GitHub Models gives free access to GPT-4o for Copilot subscribers.
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# eBay Sandbox (SBX) — developer.ebay.com
VITE_EBAY_CLIENT_ID=YourAppName-YourAppName-PRD-xxxxxxxxx-xxxxxxxx
VITE_EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# RuName: In your eBay developer portal -> Keys -> User Tokens -> "Get a Token from eBay via Your Application"
# Set the redirect URL to http://localhost:3000 and paste the assigned RuName below.
VITE_EBAY_RU_NAME=Your_App_Name-YourApp-PRD-xxxxxxxxx
VITE_EBAY_REFRESH_TOKEN=v^1.1#i^1#r^1#I^3#p^3#f^0#t^example_refresh_token
VITE_EBAY_ENV=production

# eBay publish requirements
# Find these in Seller Hub -> Listings -> Business policies
VITE_EBAY_FULFILLMENT_POLICY_ID=123456789012
VITE_EBAY_PAYMENT_POLICY_ID=123456789013
VITE_EBAY_RETURN_POLICY_ID=123456789014

# eBay inventory location used for published offers
VITE_EBAY_LOCATION_KEY=main-warehouse
VITE_EBAY_LOCATION_NAME="Main Warehouse"
VITE_EBAY_LOCATION_COUNTRY=US
VITE_EBAY_LOCATION_POSTAL_CODE=10001
VITE_EBAY_LOCATION_CITY=New York
VITE_EBAY_LOCATION_STATE=NY

# Airtable users table
VITE_AIRTABLE_USERS_TABLE_REF=tblZZZZZZZZZZZZZZ
VITE_AIRTABLE_USERS_TABLE_NAME=tblZZZZZZZZZZZZZZ
