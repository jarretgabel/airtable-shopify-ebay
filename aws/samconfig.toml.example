version = 0.1

[dev.global.parameters]
stack_name = "airtable-shopify-ebay-dev"

[dev.deploy.parameters]
region = "us-east-1"
capabilities = "CAPABILITY_IAM"
confirm_changeset = false
resolve_s3 = true
template_file = ".aws-sam/build/template.yaml"
parameter_overrides = "AirtableApiKey=replace-with-airtable-pat AirtableBaseId=replace-with-airtable-base-id AllowedAirtableTableName=replace-with-primary-listings-table AllowedAirtableViewId=replace-with-primary-view-id AirtableUsersTableRef=replace-with-users-table-ref AirtableUsersTableName=replace-with-users-table-name AirtableApprovalTableRef=replace-with-ebay-approval-table-ref AirtableApprovalTableName=replace-with-ebay-approval-table-name AirtableShopifyApprovalTableRef=replace-with-shopify-approval-table-ref AirtableShopifyApprovalTableName=replace-with-shopify-approval-table-name AirtableCombinedListingsTableRef=replace-with-combined-listings-table-ref AirtableCombinedListingsTableName=replace-with-combined-listings-table-name ShopifyStoreDomain=your-store.myshopify.com ShopifyAccessToken=replace-with-shopify-token EbayEnv=production EbayClientId=replace-with-ebay-client-id EbayClientSecret=replace-with-ebay-client-secret EbayRefreshToken=replace-with-ebay-refresh-token EbayAuthHost= EbayAppScope= EbayLocationKey=replace-with-ebay-location-key EbayLocationCountry=US EbayLocationPostalCode=10001 EbayFulfillmentPolicyId=replace-with-ebay-fulfillment-policy EbayPaymentPolicyId=replace-with-ebay-payment-policy EbayReturnPolicyId=replace-with-ebay-return-policy EbayListingApi=inventory JotformApiKey=replace-with-jotform-api-key GithubToken= OpenAiApiKey= GoogleGmailAccessToken= GoogleGmailFromEmail="

[staging.global.parameters]
stack_name = "airtable-shopify-ebay-staging"

[staging.deploy.parameters]
region = "us-east-1"
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
template_file = ".aws-sam/build/template.yaml"
parameter_overrides = "AirtableApiKey=replace-with-airtable-pat AirtableBaseId=replace-with-airtable-base-id AllowedAirtableTableName=replace-with-primary-listings-table AllowedAirtableViewId=replace-with-primary-view-id AirtableUsersTableRef=replace-with-users-table-ref AirtableUsersTableName=replace-with-users-table-name AirtableApprovalTableRef=replace-with-ebay-approval-table-ref AirtableApprovalTableName=replace-with-ebay-approval-table-name AirtableShopifyApprovalTableRef=replace-with-shopify-approval-table-ref AirtableShopifyApprovalTableName=replace-with-shopify-approval-table-name AirtableCombinedListingsTableRef=replace-with-combined-listings-table-ref AirtableCombinedListingsTableName=replace-with-combined-listings-table-name ShopifyStoreDomain=your-store.myshopify.com ShopifyAccessToken=replace-with-shopify-token EbayEnv=production EbayClientId=replace-with-ebay-client-id EbayClientSecret=replace-with-ebay-client-secret EbayRefreshToken=replace-with-ebay-refresh-token EbayAuthHost= EbayAppScope= EbayLocationKey=replace-with-ebay-location-key EbayLocationCountry=US EbayLocationPostalCode=10001 EbayFulfillmentPolicyId=replace-with-ebay-fulfillment-policy EbayPaymentPolicyId=replace-with-ebay-payment-policy EbayReturnPolicyId=replace-with-ebay-return-policy EbayListingApi=inventory JotformApiKey=replace-with-jotform-api-key GithubToken=replace-with-github-token OpenAiApiKey=replace-with-openai-api-key GoogleGmailAccessToken=replace-with-gmail-access-token GoogleGmailFromEmail=replace-with-from-email"

[prod.global.parameters]
stack_name = "airtable-shopify-ebay-prod"

[prod.deploy.parameters]
region = "us-east-1"
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
template_file = ".aws-sam/build/template.yaml"
parameter_overrides = "AirtableApiKey=replace-with-airtable-pat AirtableBaseId=replace-with-airtable-base-id AllowedAirtableTableName=replace-with-primary-listings-table AllowedAirtableViewId=replace-with-primary-view-id AirtableUsersTableRef=replace-with-users-table-ref AirtableUsersTableName=replace-with-users-table-name AirtableApprovalTableRef=replace-with-ebay-approval-table-ref AirtableApprovalTableName=replace-with-ebay-approval-table-name AirtableShopifyApprovalTableRef=replace-with-shopify-approval-table-ref AirtableShopifyApprovalTableName=replace-with-shopify-approval-table-name AirtableCombinedListingsTableRef=replace-with-combined-listings-table-ref AirtableCombinedListingsTableName=replace-with-combined-listings-table-name ShopifyStoreDomain=your-store.myshopify.com ShopifyAccessToken=replace-with-shopify-token EbayEnv=production EbayClientId=replace-with-ebay-client-id EbayClientSecret=replace-with-ebay-client-secret EbayRefreshToken=replace-with-ebay-refresh-token EbayAuthHost= EbayAppScope= EbayLocationKey=replace-with-ebay-location-key EbayLocationCountry=US EbayLocationPostalCode=10001 EbayFulfillmentPolicyId=replace-with-ebay-fulfillment-policy EbayPaymentPolicyId=replace-with-ebay-payment-policy EbayReturnPolicyId=replace-with-ebay-return-policy EbayListingApi=inventory JotformApiKey=replace-with-jotform-api-key GithubToken=replace-with-github-token OpenAiApiKey=replace-with-openai-api-key GoogleGmailAccessToken=replace-with-gmail-access-token GoogleGmailFromEmail=replace-with-from-email"